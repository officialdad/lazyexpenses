    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Merge every unlocked PDF into one item with unique binary keys, ready to zip.\nconst items = $input.all();\nconst bankItems = $('get bank').all();\n\nconst binary = {};\nconst keys = [];\n\nitems.forEach((item, i) => {\n  if (!item.binary || !item.binary.data) return; // skip failed unlocks\n  const bank = (bankItems[i] && bankItems[i].json.bankName) || 'bank';\n  const key = `file_${i}`;\n  binary[key] = item.binary.data;\n  binary[key].fileName = `${bank}_statement_${i + 1}.pdf`;\n  keys.push(key);\n});\n\nif (keys.length === 0) {\n  return [{ json: { fileKeys: '', count: 0, message: 'No unlocked PDFs' }, binary: {} }];\n}\n\nreturn [{ json: { fileKeys: keys.join(','), count: keys.length }, binary }];\n"
      },
