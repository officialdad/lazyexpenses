    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Detect bank from email text/html, keep only items that have a PDF AND a known bank.\nconst banks = [\"cimb\", \"maybank\", \"alliance\", \"sc\", \"hsbc\", \"rhb\"];\nconst regex = new RegExp(`\\\\b(${banks.join(\"|\")})\\\\b`, \"i\");\n\nconst out = [];\n\nfor (const item of $input.all()) {\n  const html = item.json.html || item.json.text || \"\";\n  const match = html.match(regex);\n  const bankName = match ? match[1].toLowerCase() : null;\n\n  // find first PDF attachment\n  let firstPdf = null;\n  if (item.binary) {\n    for (const key of Object.keys(item.binary)) {\n      if (item.binary[key].mimeType === 'application/pdf') {\n        firstPdf = item.binary[key];\n        break;\n      }\n    }\n  }\n\n  // skip emails with no PDF or unknown bank (can't derive password)\n  if (!firstPdf || !bankName) continue;\n\n  out.push({\n    json: {\n      bankName,\n      subject: item.json.subject,\n      emailId: item.json.id\n    },\n    binary: { data: firstPdf }\n  });\n}\n\nreturn out;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -520,
        0
      ],
      "id": "a1b2c3d4-0003-4000-8000-000000000003",
      "name": "get bank",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Map bankName -> default PDF password\nconst inputFieldName = \"bankName\";\nconst outputFieldName = \"password\";\n\nswitch ($input.item.json[inputFieldName]) {\n  case 'maybank':\n    $input.item.json[outputFieldName] = '***REMOVED***';\n    break;\n  case 'cimb':\n    $input.item.json[outputFieldName] = '***REMOVED***';\n    break;\n  case 'sc':\n    $input.item.json[outputFieldName] = '***REMOVED***';\n    break;\n  case 'alliance':\n    $input.item.json[outputFieldName] = '***REMOVED***';\n    break;\n  case 'hsbc':\n    $input.item.json[outputFieldName] = '***REMOVED***';\n    break;\n  case 'rhb':\n    $input.item.json[outputFieldName] = '***REMOVED***';\n    break;\n  default:\n    $input.item.json.error = 'Could not validate bankName';\n}\n\nreturn $input.item;"
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "set pass",
